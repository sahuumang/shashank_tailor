<!-- WHY -->
<section class="about"><div class="wrap">
  <div class="sec-head reveal" style="text-align:center;margin-left:auto;margin-right:auto">
    <div class="sec-tag">Why Choose Us</div>
    <h2 class="sec-title">Good reasons to <i>visit us.</i></h2>
  </div>
  <div class="why-grid">
    <div class="why-item reveal"><div class="n">1</div><h4>Perfect Fitting</h4><p>Careful measurements so every garment sits right on you.</p></div>
    <div class="why-item reveal"><div class="n">2</div><h4>Quality Fabric</h4><p>A wide range of trusted suiting and shirting cloth.</p></div>
    <div class="why-item reveal"><div class="n">3</div><h4>On-Time Delivery</h4><p>Your order finished neatly and ready when promised.</p></div>
