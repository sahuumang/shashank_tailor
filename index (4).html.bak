<!-- SERVICES (TAILORING) -->
<section id="services"><div class="wrap">
  <div class="sec-head reveal">
    <div class="sec-tag">Tailoring Services</div>
    <h2 class="sec-title">Stitched to <i>fit you perfectly.</i></h2>
    <p class="sec-intro">Expert gents' tailoring for every occasion — formal, traditional, and everyday.</p>
  </div>
  <div class="cards">
    <div class="card reveal">
      <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M16 3 12 7 8 3M12 7v14M6 21h12"/><path d="M6 21 4 9l8-2 8 2-2 12"/></svg></div>
      <h3>Suits &amp; Blazers</h3><p>Sharp, well-fitted formal suits, blazers and waistcoats — tailored for office, events and interviews.</p>
    </div>
    <div class="card reveal">
      <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 2v20M7 5l5-3 5 3M5 9l2-4M19 9l-2-4M5 9v11h14V9"/></svg></div>
      <h3>Sherwani &amp; Indo-Western</h3><p>Royal sherwanis and indo-western outfits for weddings, festivals and special occasions.</p>
    </div>
    <div class="card reveal">
      <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M9 2 6 5v17h12V5l-3-3M9 2h6M9 2v3h6V2"/></svg></div>
      <h3>Kurta-Pajama</h3><p>Comfortable, well-cut kurta-pajama and traditional wear in the fabric and style you like.</p>
    </div>
    <div class="card reveal">
      <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M7 3 4 6v15h16V6l-3-3-2 2-3-2-3 2-2-2zM10 4l2 1 2-1"/></svg></div>
      <h3>Shirts</h3><p>Custom shirts — formal and casual — stitched to your exact measurement and collar style.</p>
    </div>
    <div class="card reveal">
      <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M8 2h8l-1 9 3 11h-5l-1-8-1 8H5l3-11z"/></svg></div>
      <h3>Trousers &amp; Pants</h3><p>Formal trousers and pants with a clean finish and the right fit at waist and length.</p>
    </div>
    <div class="card reveal">
      <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M20 4 8.5 15.5M14.5 9.5 20 20M8.6 8.6 12 12"/></svg></div>
      <h3>Alterations &amp; Repairs</h3><p>Quick, neat alterations and repairs — resizing, fall-pico, and finishing touches.</p>
    </div>
  </div>
</div></section>

<!-- FABRIC -->
